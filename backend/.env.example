# Redis — broker and result backend for Celery compilation jobs
REDIS_URL=redis://localhost:6379/0

# Where session files (datasets, notebooks, models) are stored
# Use /tmp/obsidian-sessions for local dev; Docker sets this via docker-compose
SESSIONS_DIR=/tmp/obsidian-sessions

# How long a session lives before being purged (hours)
SESSION_TTL_HOURS=4

# Maximum upload size
MAX_FILE_SIZE_MB=500

# Compilation resource limits (increase for more powerful machines)
MAX_TRAINING_MINUTES=10   # hard timeout for the training subprocess
MAX_MEMORY_GB=12          # max address space (RLIMIT_AS) for the subprocess
MAX_OUTPUT_GB=10          # max output file size (RLIMIT_FSIZE) for the subprocess
MAX_EPOCHS=200            # passed to the AI as the max epochs constraint

# Rate limiting (requests per minute)
RATE_LIMIT_USER=60
RATE_LIMIT_API_CLIENT=100

# JWT — required only by the dormant auth scaffold (not used by open source v1)
JWT_ALGORITHM=HS256
