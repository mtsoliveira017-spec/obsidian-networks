# Redis — broker and result backend for Celery compilation jobs
REDIS_URL=redis://localhost:6379/0

# Where session files (datasets, notebooks, models) are stored
# Use /tmp/obsidian-sessions for local dev; Docker sets this via docker-compose
SESSIONS_DIR=/tmp/obsidian-sessions

# How long a session lives before being purged (hours)
SESSION_TTL_HOURS=4

# Maximum upload size
MAX_FILE_SIZE_MB=500

# Rate limiting (requests per minute)
RATE_LIMIT_USER=60
RATE_LIMIT_API_CLIENT=100

# JWT — required only by the dormant auth scaffold (not used by open source v1)
JWT_ALGORITHM=HS256
